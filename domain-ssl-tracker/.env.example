# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/domain_tracker

# SMTP Email Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_FROM_EMAIL=your@gmail.com
ALERT_TO_EMAIL=alerts@yourdomain.com

# Login credentials (set in .env)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SECRET_KEY=change-this-to-a-random-string-in-production
